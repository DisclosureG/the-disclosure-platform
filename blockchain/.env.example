# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Private key of the wallet that deploys the contract (0x-prefixed).
# On testnet use a throwaway key — never use a wallet holding real funds.
DEPLOYER_PRIVATE_KEY=0x...

# BNB Smart Chain RPC endpoints.
# Public fallbacks are already set in hardhat.config.js; override here if needed.
BSC_TESTNET_RPC=https://bsc-testnet-rpc.publicnode.com
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# BscScan API key for contract verification (optional).
# Get one free at https://bscscan.com/register
BSCSCAN_API_KEY=
