# Copy this file to .env.local (or set these in your host's env) and fill in
# your values. NEVER commit .env / .env.local — they are git-ignored.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and the public anon key (safe to expose; Row Level Security
# protects the data). Find both in Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── EvidenceConsensus contract ──────────────────────────────────────────────
# Chain id of the network the contract is deployed on (97 = BSC testnet,
# 56 = BSC mainnet).
VITE_CONSENSUS_CHAIN_ID=97

# Address of the deployed EvidenceConsensus contract.
VITE_CONSENSUS_ADDR=0x...

# Optional: a read-only RPC URL so contract reads (peer count, thresholds, the
# taxonomy) work before a wallet is connected / when MetaMask is absent.
# Falls back to the connected wallet's provider if unset.
VITE_CONSENSUS_READ_RPC=https://bsc-testnet-rpc.publicnode.com
