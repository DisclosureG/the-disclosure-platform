# OS / editor cruft
.DS_Store

# React / Vite build files
node_modules/
dist/
.vite/

# Local Netlify folder
.netlify

# Environment / secrets
.env
.env.local
.env.*.local

# Claude Code per-user config
.claude/

# Agent / editor tooling caches (not part of the product)
.agents/

# Hardhat build artifacts (regenerated by `npx hardhat compile`)
blockchain/artifacts/
blockchain/cache/

# Supabase CLI temp
supabase/.temp/

# LaTeX build artifacts (whitepaper .tex sources + compiled .pdf stay tracked)
public/artefacts/*.aux
public/artefacts/*.log
public/artefacts/*.out
public/artefacts/*.toc
public/artefacts/*.synctex.gz
public/artefacts/*.fls
public/artefacts/*.fdb_latexmk
